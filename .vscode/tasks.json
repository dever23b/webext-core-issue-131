{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Dev",
      "type": "npm",
      "script": "dev",
      "problemMatcher": [],
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false,
        "group": "background"
      },
      "runOptions": {
        "runOn": "folderOpen",
        "instanceLimit": 1,
        "instancePolicy": "terminateOldest"
      }
    },
    {
      "label": "Watch",
      "type": "npm",
      "script": "watch",
      "problemMatcher": ["$tsc-watch"],
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false,
        "group": "background"
      },
      "runOptions": {
        "runOn": "folderOpen",
        "instanceLimit": 1,
        "instancePolicy": "terminateOldest"
      }
    }
  ]
}
